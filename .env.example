# =========================================================================
# Eisenhower Matrix Task Orchestrator - Environment Variables Template
# =========================================================================
# Copy this file to a new file named '.env' and fill in your private values.
# DO NOT commit the '.env' file containing real credentials to Git.

# Discord Configuration
DISCORD_WEBHOOK_ID=your_discord_webhook_id_here
DISCORD_WEBHOOK_CRED_ID=your_discord_webhook_credential_id_here

# Google Calendar Configuration
GOOGLE_CALENDAR_ID=your_google_calendar_email_or_id_here
GOOGLE_CALENDAR_CRED_ID=your_google_calendar_credential_id_here

# Google Gemini / LLM Configuration
GOOGLE_GEMINI_CRED_ID=your_google_gemini_credential_id_here

# Gmail Configuration
GMAIL_WEBHOOK_ID=your_gmail_webhook_id_here
GMAIL_CRED_ID=your_gmail_credential_id_here
GMAIL_RECIPIENT=your_delegate_email_address_here

# Google Sheets Configuration
GOOGLE_SHEETS_CRED_ID=your_google_sheets_credential_id_here
GOOGLE_SHEETS_DOC_ID=your_google_spreadsheet_document_id_here
GOOGLE_SHEETS_SHEET_ID=your_google_sheet_gid_or_name_here
EVALUATION_SPREADSHEET_ID=your_evaluation_spreadsheet_id_here
